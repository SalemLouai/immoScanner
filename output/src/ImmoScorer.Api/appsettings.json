{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=immoscorer.db"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:5173" ]
  },
  "AntiBot": {
    "MinDelayMs": 3000,
    "MaxDelayMs": 8000,
    "BaseBackoffMs": 2000,
    "MaxBackoffAttempts": 5,
    "CaptchaPauseMs": 300000,
    "RobotsTxtCacheHours": 24
  },
  "Scraping": {
    "Headless": true,
    "RecycleBrowserAfterPages": 20,
    "NavigationTimeoutMs": 30000,
    "Mode": "Fixture"
  },
  "Queue": {
    "Provider": "InMemory",
    "QueueName": "scraping-jobs",
    "VisibilityTimeoutSeconds": 300
  },
  "Dvf": {
    "BaseUrl": "https://api.dvf.etalab.gouv.fr/geoapi/dvf/",
    "CacheDirectory": "./dvf-cache",
    "CacheTtlDays": 90
  },
  "AllowedHosts": "*"
}
